# Dev snippets
rubocopdiff() {
  local base_ref
  if [[ -n "$1" ]]; then
    base_ref="${1}@{u}"
  else
    base_ref="@{u}"
  fi
  if ! git rev-parse -q --verify "$base_ref" >/dev/null 2>&1; then
    if git rev-parse -q --verify origin/main >/dev/null 2>&1; then
      base_ref="origin/main"
    elif git rev-parse -q --verify origin/master >/dev/null 2>&1; then
      base_ref="origin/master"
    else
      echo "rubocopdiff: no upstream for current branch and no origin/main or origin/master" >&2
      return 1
    fi
  fi
  git diff-tree -r --relative --no-commit-id --name-only --diff-filter=d "$base_ref" HEAD -- ':(exclude)*schema.rb' |
    xargs bundle exec rubocop -A
}

django_delete_migrations() {
find . -path "*/migrations/*.py" -not -name "__init__.py" -delete
find . -path "*/migrations/*.pyc" -delete
}

gitprune() {
git branch --merged master | grep -v '^[ *]*master$' | xargs git branch -d
}

